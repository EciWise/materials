# Application
NODE_ENV=development
PORT=3000
SWAGGER_ENABLED=true

# Storage Provider: 'azure' (default) or 's3'
STORAGE_PROVIDER=azure

# Message Bus Provider: 'azure' (default) or 'rabbitmq'
MESSAGE_BUS_PROVIDER=azure

# --- Azure Storage (required when STORAGE_PROVIDER=azure) ---
BLOB_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=your-key;EndpointSuffix=core.windows.net
BLOB_STORAGE_ACCOUNT_NAME=your-account-name

# --- AWS S3 (required when STORAGE_PROVIDER=s3) ---
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-bucket-name

# --- Azure Service Bus (required when MESSAGE_BUS_PROVIDER=azure) ---
SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=your-key

# --- RabbitMQ (required when MESSAGE_BUS_PROVIDER=rabbitmq) ---
RABBITMQ_URL=amqp://user:password@localhost:5672

# Database
DATABASE_URL="postgresql://postgres"
DIRECT_URL="postgresql://postgres"
