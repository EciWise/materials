generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Calificaciones {
  id           Int        @id @default(autoincrement())
  idMaterial   String
  userId       String
  calificacion Int
  comentario   String?
  createdAt    DateTime   @default(now())
  Materiales   Materiales @relation(fields: [idMaterial], references: [id], onDelete: Cascade)
  usuarios     usuarios   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MaterialTags {
  idTag      Int
  idMaterial String
  Materiales Materiales @relation(fields: [idMaterial], references: [id], onDelete: Cascade)
  Tags       Tags       @relation(fields: [idTag], references: [id], onDelete: Cascade)

  @@id([idTag, idMaterial])
  @@index([idMaterial])
}

model Tags {
  id           Int            @id @default(autoincrement())
  tag          String         @unique
  MaterialTags MaterialTags[]
}

model usuarios {
  id                                  String               @id
  email                               String               @unique
  nombre                              String
  apellido                            String
  telefono                            String?
  biografia                           String?
  semestre                            Int                  @default(1)
  google_id                           String?              @unique
  avatar_url                          String?
  rol_id                              Int                  @default(1)
  estado_id                           Int                  @default(1)
  ultimo_login                        DateTime?
  disponibilidad                      Json?
  created_at                          DateTime             @default(now())
  updated_at                          DateTime
  Materiales                          Materiales[]
  Calificaciones                      Calificaciones[]

  @@index([email])
  @@index([estado_id])
  @@index([rol_id])
}

model Materiales {
  id             String           @id
  nombre         String
  userId         String
  url            String
  extension      String
  descripcion    String?
  vistos         Int              @default(0)
  descargas      Int              @default(0)
  createdAt      DateTime         @default(now())
  hash           String?          @unique
  updatedAt      DateTime
  Calificaciones Calificaciones[]
  MaterialTags   MaterialTags[]
  usuarios       usuarios         @relation(fields: [userId], references: [id], onDelete: Cascade)
  Resumen        Resumen[]

  @@index([extension])
  @@index([userId])
}

model Resumen {
  id         Int        @id @default(autoincrement())
  idMaterial String
  resumen    String
  Materiales Materiales @relation(fields: [idMaterial], references: [id], onDelete: Cascade)
}
